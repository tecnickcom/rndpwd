{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "description": "JSON schema for rndpwd configuration",
  "properties": {
    "clients": {
      "additionalProperties": false,
      "description": "Configuration for external service clients",
      "properties": {
        "ipify": {
          "additionalProperties": false,
          "description": "Configuration for the ipify service client",
          "examples": [
            {
              "address": "https://api.ipify.org",
              "timeout": 15
            }
          ],
          "properties": {
            "address": {
              "default": "",
              "description": "Base URL of the service",
              "examples": [
                "https://api.ipify.org"
              ],
              "title": "Address",
              "type": "string"
            },
            "timeout": {
              "default": 1,
              "description": "HTTP client timeout [seconds]",
              "examples": [
                15
              ],
              "title": "Timeout",
              "type": "integer"
            }
          },
          "required": [
            "address",
            "timeout"
          ],
          "title": "ipify service client",
          "type": "object"
        }
      },
      "required": [
        "ipify"
      ],
      "title": "Clients",
      "type": "object"
    },
    "enabled": {
      "default": true,
      "description": "Enable or disable the service",
      "title": "Enabled",
      "type": "boolean"
    },
    "log": {
      "additionalProperties": false,
      "description": "Logger settings",
      "properties": {
        "address": {
          "default": "",
          "description": "(OPTIONAL) Network address of the (r)Syslog daemon (ip:port) or just (:port)",
          "type": "string"
        },
        "format": {
          "default": "JSON",
          "description": "Defines the default log format",
          "enum": [
            "CONSOLE",
            "JSON"
          ],
          "type": "string"
        },
        "level": {
          "default": "DEBUG",
          "description": "Defines the default log level",
          "enum": [
            "EMERGENCY",
            "ALERT",
            "CRITICAL",
            "ERROR",
            "WARNING",
            "NOTICE",
            "INFO",
            "DEBUG"
          ],
          "type": "string"
        },
        "network": {
          "default": "",
          "description": "(OPTIONAL) Network type used by the (r)Syslog",
          "enum": [
            "",
            "udp",
            "tcp"
          ],
          "type": "string"
        }
      },
      "required": [
        "address",
        "format",
        "level",
        "network"
      ],
      "title": "Logger",
      "type": "object"
    },
    "random": {
      "additionalProperties": false,
      "description": "Configuration of the random generator",
      "examples": [
        {
          "charset": "0123456789abcdefghijklmnopqrstuvwxyz",
          "length": 32,
          "quantity": 10
        }
      ],
      "properties": {
        "charset": {
          "default": "!\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~",
          "description": "String containing the valid characters for a password. When this key is omitted the application default is the full printable ASCII set; the shipped configuration intentionally sets a smaller subset that omits quote and shell-sensitive characters.",
          "examples": [
            "0123456789abcdefghijklmnopqrstuvwxyz"
          ],
          "type": "string"
        },
        "length": {
          "default": 32,
          "description": "Length of each password (number of characters or bytes)",
          "examples": [
            32
          ],
          "type": "integer"
        },
        "quantity": {
          "default": 10,
          "description": "Number of passwords to return",
          "examples": [
            10
          ],
          "type": "integer"
        }
      },
      "required": [
        "charset",
        "length",
        "quantity"
      ],
      "title": "Settings for the random generator",
      "type": "object"
    },
    "remoteConfigData": {
      "default": "",
      "description": "Base64 encoded JSON configuration data to be used with the 'envvar' provider",
      "title": "Remote Configuration Data",
      "type": "string"
    },
    "remoteConfigEndpoint": {
      "default": "",
      "description": "Remote configuration URL (ip:port), passed to the custom remote loader",
      "title": "Remote Configuration Endpoint",
      "type": "string"
    },
    "remoteConfigPath": {
      "default": "",
      "description": "Remote configuration path in which to search for the configuration data (e.g. '/config/rndpwd'), passed to the custom remote loader",
      "title": "Remote Configuration Path",
      "type": "string"
    },
    "remoteConfigProvider": {
      "default": "",
      "description": "Remote configuration source type: 'envvar' or empty (other values require a custom remote loader registered via the config.WithRemoteLoader option)",
      "enum": [
        "",
        "envvar"
      ],
      "title": "Remote Configuration Provider",
      "type": "string"
    },
    "remoteConfigSecretKeyring": {
      "default": "",
      "description": "Path to an optional secret keyring used by the custom remote loader to decrypt the remote configuration data (e.g. '/etc/rndpwd/configkey.gpg')",
      "title": "Remote Configuration Secret Keyring",
      "type": "string"
    },
    "servers": {
      "additionalProperties": false,
      "description": "Configuration for exposed servers",
      "properties": {
        "monitoring": {
          "additionalProperties": false,
          "description": "Configuration for the monitoring server",
          "examples": [
            {
              "address": ":8072",
              "timeout": 60
            }
          ],
          "properties": {
            "address": {
              "default": "",
              "description": "HTTP address (ip:port) or just (:port)",
              "examples": [
                ":8072"
              ],
              "title": "Address",
              "type": "string"
            },
            "timeout": {
              "description": "HTTP request timeout [seconds]",
              "examples": [
                60
              ],
              "title": "Timeout",
              "type": "integer"
            }
          },
          "required": [
            "address",
            "timeout"
          ],
          "title": "Monitoring HTTP server",
          "type": "object"
        },
        "public": {
          "additionalProperties": false,
          "description": "Configuration for the public server",
          "examples": [
            {
              "address": ":8071",
              "timeout": 60
            }
          ],
          "properties": {
            "address": {
              "default": "",
              "description": "HTTP address (ip:port) or just (:port)",
              "examples": [
                ":8071"
              ],
              "title": "Address",
              "type": "string"
            },
            "timeout": {
              "description": "HTTP request timeout [seconds]",
              "examples": [
                60
              ],
              "title": "Timeout",
              "type": "integer"
            }
          },
          "required": [
            "address",
            "timeout"
          ],
          "title": "Public HTTP server",
          "type": "object"
        }
      },
      "required": [
        "monitoring",
        "public"
      ],
      "title": "Servers",
      "type": "object"
    },
    "shutdown_timeout": {
      "default": 30,
      "description": "Time in seconds to wait on exit for a graceful shutdown.",
      "title": "ShutDown Timeout",
      "type": "integer"
    }
  },
  "required": [
    "clients",
    "enabled",
    "log",
    "servers",
    "random"
  ],
  "title": "Configuration for rndpwd",
  "type": "object"
}
